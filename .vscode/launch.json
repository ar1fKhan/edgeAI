{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: Video Pipeline",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/edge_inspector",
            "args": [
                "--video", "${workspaceFolder}/data/test_videos/synthetic_cans.mp4",
                "--verbose"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set disassembly flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug"
        },
        {
            "name": "Debug: Video Pipeline (Loop)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/edge_inspector",
            "args": [
                "--video", "${workspaceFolder}/data/test_videos/synthetic_cans.mp4",
                "--loop",
                "--verbose"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug"
        },
        {
            "name": "Debug: Single Image",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/edge_inspector",
            "args": [
                "--image", "${input:imagePath}",
                "--verbose"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug"
        },
        {
            "name": "Debug: Capture Images",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/capture_images",
            "args": [
                "--video", "${workspaceFolder}/data/test_videos/synthetic_cans.mp4",
                "--no-preview",
                "-n", "10",
                "-o", "${workspaceFolder}/data/captures"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug"
        },
        {
            "name": "Debug: Benchmark",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/benchmark_inference",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug"
        },
        {
            "name": "Debug: Unit Tests",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/${input:testName}",
            "args": [
                "--gtest_color=yes"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug"
        }
    ],
    "inputs": [
        {
            "id": "imagePath",
            "type": "promptString",
            "description": "Path to image file to inspect",
            "default": "${workspaceFolder}/data/captures/capture_001.jpg"
        },
        {
            "id": "testName",
            "type": "pickString",
            "description": "Select test suite to debug",
            "options": [
                "test_types",
                "test_preprocessing",
                "test_postprocessing",
                "test_decision",
                "test_database",
                "test_frame_queue",
                "test_integration"
            ],
            "default": "test_integration"
        }
    ]
}
